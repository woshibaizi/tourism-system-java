# ===== Agent 服务基础配置 =====
AGENT_HOST=0.0.0.0
AGENT_PORT=9000
AGENT_NAME=personalized-travel-agent
AGENT_VERSION=0.1.0
AGENT_TRACE_DIR=./data/traces
AGENT_DB_DIR=./data

# ===== Java 后端回调地址 =====
TOURISM_BACKEND_BASE_URL=http://127.0.0.1:8080
TOURISM_BACKEND_TIMEOUT_MS=5000

# ===== 大模型配置 =====
# 提供商类型: openai_compatible / anthropic
LLM_PROVIDER=openai_compatible

# ===== 文本模型（对话 / 推理 / 工具调用） =====
# 推荐: DeepSeek（高性价比，中文优秀）
# DeepSeek: deepseek-chat / deepseek-reasoner
# OpenAI: gpt-4o / gpt-4o-mini
# 通义千问: qwen-plus / qwen-max
TEXT_LLM_MODEL=deepseek-chat
TEXT_LLM_BASE_URL=https://api.deepseek.com
TEXT_LLM_API_KEY=your-deepseek-api-key-here

# ===== 视觉模型（图片理解 / 多模态分析） =====
# 推荐: 通义千问 Qwen VL（国内可用，中文优化）
# qwen-vl-max: 最强视觉理解，推荐
# qwen-vl-plus: 性价比之选
VISION_LLM_MODEL=qwen-vl-max
VISION_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_LLM_API_KEY=your-dashscope-api-key-here

# ===== 混合模式开关 =====
# true:  图片任务 → 视觉模型，文本任务 → 文本模型（推荐）
# false: 所有任务 → 文本模型（降级模式）
HYBRID_MODE=true

# ===== 兼容旧配置（未配置独立模型时使用） =====
# LLM_MODEL 和 LLM_API_KEY 作为兜底，当 TEXT_LLM_API_KEY 未设置时使用
LLM_MODEL=deepseek-chat
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com

# 请求参数
LLM_TIMEOUT_MS=30000
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_STREAM=false

# ===== 小红书 XhsSkills 配置 =====
# 系统级 Cookie（用于搜索、获取笔记等只读操作）
# 从浏览器登录 www.xiaohongshu.com 后，F12 → Application → Cookies 复制
XHS_SYSTEM_COOKIES_STR=

# Cookie 加密密钥（用于加密存储用户的小红书 Cookie，32 字节 hex）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
XHS_COOKIE_ENCRYPTION_KEY=
