# ===== Agent 服务基础配置 =====
AGENT_HOST=0.0.0.0
AGENT_PORT=9000
AGENT_NAME=personalized-travel-agent
AGENT_VERSION=0.1.0
AGENT_TRACE_DIR=./data/traces
AGENT_DB_DIR=./data

# ===== Java 后端回调地址 =====
TOURISM_BACKEND_BASE_URL=http://127.0.0.1:8080
TOURISM_BACKEND_TIMEOUT_MS=5000

# ===== 大模型配置 =====
# 提供商类型: openai_compatible / anthropic
LLM_PROVIDER=openai_compatible

# 模型名称
# DeepSeek: deepseek-chat / deepseek-reasoner
# OpenAI: gpt-4o / gpt-4o-mini
# 通义千问: qwen-plus / qwen-max
# Anthropic: claude-opus-4-7 / claude-sonnet-4-6
LLM_MODEL=deepseek-chat

# API 密钥（必填，未配置时 Agent 降级为规则模式）
LLM_API_KEY=your-api-key-here

# API 地址（OpenAI 兼容接口可自定义）
# DeepSeek: https://api.deepseek.com
# OpenAI: https://api.openai.com/v1
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://api.deepseek.com

# 请求参数
LLM_TIMEOUT_MS=30000
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_STREAM=false
